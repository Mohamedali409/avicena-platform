        { "name": "Get Notifications (Doctor)", "request": { "method": "GET", "header": [{"key":"dtoken","value":"{{doctorToken}}"}], "url": { "raw": "{{baseUrl}}/api/notifications?page=1&limit=20", "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}] } } },
