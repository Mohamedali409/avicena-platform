          "request": { "method": "GET", "header": [{"key":"dtoken","value":"{{doctorToken}}"}], "url": { "raw": "{{baseUrl}}/api/chat/doctor/requests?status=pending", "query": [{"key":"status","value":"pending"}] } }
        },
        {
          "name": "4. Doctor — Accept Request ✅",
          "request": { "method": "PATCH", "header": [{"key":"dtoken","value":"{{doctorToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/chat/doctor/requests/accept", "body": { "mode": "raw", "raw": "{\n  \"roomId\": \"{{roomId}}\"\n}" } }
        },
        {
          "name": "4b. Doctor — Reject Request ❌",
          "request": { "method": "PATCH", "header": [{"key":"dtoken","value":"{{doctorToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/chat/doctor/requests/reject", "body": { "mode": "raw", "raw": "{\n  \"roomId\": \"{{roomId}}\",\n  \"rejectReason\": \"أنا غير متخصص في هذه الحالة\"\n}" } }
        },
        {
          "name": "5. Get Room Messages",
          "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": { "raw": "{{baseUrl}}/api/chat/room/{{roomId}}?page=1&limit=30", "query": [{"key":"page","value":"1"},{"key":"limit","value":"30"}] } }
        },
        { "name": "Get My Conversations (Patient)", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": "{{baseUrl}}/api/chat/conversations" } },
        { "name": "Get My Conversations (Doctor)", "request": { "method": "GET", "header": [{"key":"dtoken","value":"{{doctorToken}}"}], "url": "{{baseUrl}}/api/chat/conversations" } },
        { "name": "Get Room ID with Doctor", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": "{{baseUrl}}/api/chat/room/{{doctorId}}/id" } },
        { "name": "Get Unread Count", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": "{{baseUrl}}/api/chat/room/{{roomId}}/unread" } },
        { "name": "Mark Room as Read", "request": { "method": "PATCH", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": "{{baseUrl}}/api/chat/room/{{roomId}}/read" } }
      ]
    },
    {
      "name": "🤖 Medical AI (RAG) ✨",
      "item": [
        {
          "name": "1. Get Patient Summary (Auto on chat open)",
          "request": {
            "method": "GET",
            "header": [{"key":"dtoken","value":"{{doctorToken}}"}],
            "url": "{{baseUrl}}/api/medical-ai/summary/{{userId}}",
            "description": "الدكتور يفتح المحادثة مع مريض → الـ AI يولّد ملخص تلقائي عن حالته بناءً على كل تقاريره"
          }
        },
        {
          "name": "2. Ask Question About Patient",
          "request": {
            "method": "POST",
            "header": [{"key":"dtoken","value":"{{doctorToken}}"},{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/medical-ai/ask",
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"question\": \"ايه الأدوية اللي الدكتور كتبها للمريض ده قبل كده؟\",\n  \"chatHistory\": []\n}" },
            "description": "الدكتور يسأل سؤال عن المريض — الـ AI يجاوب من التقارير الحقيقية بس"
          }
        },
        {
          "name": "3. Ask — Drug Check",
          "request": {
            "method": "POST",
            "header": [{"key":"dtoken","value":"{{doctorToken}}"},{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/medical-ai/ask",
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"question\": \"هل المريض عنده حساسية من أي دواء أو كان فيه تفاعل دوائي سابق؟\",\n  \"chatHistory\": []\n}" }
          }
        },
        {
          "name": "4. Ask — Diagnosis History",
          "request": {
            "method": "POST",
            "header": [{"key":"dtoken","value":"{{doctorToken}}"},{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/medical-ai/ask",
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"question\": \"ايه أهم التشخيصات السابقة للمريض؟\",\n  \"chatHistory\": [\n    {\"role\": \"user\", \"content\": \"ايه الأدوية اللي اتكتبتله؟\"},\n    {\"role\": \"assistant\", \"content\": \"تم وصف Amoxicillin 500mg لمدة 7 أيام\"}\n  ]\n}" }
          }
        },
        {
          "name": "5. Index New Report Manually",
          "request": {
            "method": "POST",
            "header": [{"key":"dtoken","value":"{{doctorToken}}"},{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/medical-ai/index-report",
            "body": { "mode": "raw", "raw": "{\n  \"report\": {\n    \"_id\": \"{{reportId}}\",\n    \"userId\": \"{{userId}}\",\n    \"docId\": \"{{doctorId}}\",\n    \"userData\": {\"name\": \"Ahmed Mohamed\"},\n    \"complaint\": \"صداع وحرارة\",\n    \"examination\": \"حرارة 38.5\",\n    \"diagnosis\": \"التهاب في الحلق\",\n    \"treatment\": [{\"name\": \"Amoxicillin\", \"dosage\": \"500mg\", \"duration\": \"7 أيام\"}],\n    \"notes\": \"راحة تامة\",\n    \"createdAt\": \"2026-01-15T10:00:00.000Z\"\n  }\n}" }
          }
        }
      ]
    },
