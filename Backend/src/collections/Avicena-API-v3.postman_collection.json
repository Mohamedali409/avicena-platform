    {
      "name": "💬 Chat + Request Flow ✨",
      "item": [
        {
          "name": "1. Patient — Send Chat Request",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if(r.data?.request?.roomId) pm.collectionVariables.set('roomId', r.data.request.roomId);"] } }],
          "request": { "method": "POST", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/chat/request", "body": { "mode": "raw", "raw": "{\n  \"docId\": \"{{doctorId}}\",\n  \"initialMessage\": \"دكتور عندي سؤال عن الدواء اللي كتبته\"\n}" } }
        },
        {
          "name": "2. Patient — Get My Requests",
          "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": "{{baseUrl}}/api/chat/my-requests" }
        },
        {
