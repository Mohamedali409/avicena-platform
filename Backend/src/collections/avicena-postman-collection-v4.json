          "request": { "method": "POST", "header": [{"key":"dtoken","value":"{{doctorToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/doctor/reports", "body": { "mode": "raw", "raw": "{\n  \"appointmentId\": \"{{appointmentId}}\",\n  \"complaint\": \"صداع وارتفاع في الحرارة\",\n  \"examination\": \"حرارة 38.5، ضغط طبيعي\",\n  \"diagnosis\": \"التهاب في الحلق\",\n  \"treatment\": [\n    {\"name\": \"Amoxicillin\", \"dosage\": \"500mg\", \"duration\": \"7 أيام\"},\n    {\"name\": \"Paracetamol\", \"dosage\": \"1g\", \"duration\": \"عند الحاجة\"}\n  ],\n  \"notes\": \"راحة تامة وشرب سوائل\",\n  \"nextVisit\": \"2026-02-01\"\n}" } }
        },
        { "name": "Get All Reports", "request": { "method": "GET", "header": [{"key":"dtoken","value":"{{doctorToken}}"}], "url": "{{baseUrl}}/api/doctor/reports" } },
        { "name": "Get Patient Reports", "request": { "method": "POST", "header": [{"key":"dtoken","value":"{{doctorToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/doctor/reports/patient", "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\"\n}" } } },
        { "name": "Edit Report", "request": { "method": "PUT", "header": [{"key":"dtoken","value":"{{doctorToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/doctor/reports", "body": { "mode": "raw", "raw": "{\n  \"reportId\": \"{{reportId}}\",\n  \"complaint\": \"صداع شديد\",\n  \"examination\": \"حرارة 39\",\n  \"diagnosis\": \"التهاب حاد\",\n  \"treatment\": [{\"name\": \"Augmentin\", \"dosage\": \"625mg\", \"duration\": \"10 أيام\"}]\n}" } } },
        { "name": "Delete Report", "request": { "method": "DELETE", "header": [{"key":"dtoken","value":"{{doctorToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/doctor/reports", "body": { "mode": "raw", "raw": "{\n  \"reportId\": \"{{reportId}}\"\n}" } } },
        {
          "name": "Create Consultation",
