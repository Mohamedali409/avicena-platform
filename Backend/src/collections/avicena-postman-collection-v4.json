{
  "info": {
    "name": "Avicena Platform API v4",
    "_postman_id": "avicena-v4",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Avicena Healthcare SaaS Platform — Full API Collection\nUpdated: Unified cookie-based login (all roles), OTP email verification, forgot/reset password, Pharmacy module (products, inventory, medication schedules, orders, applications), Health & Metrics endpoints.\n\n⚠️ Login now sets httpOnly cookies (accessToken/refreshToken) instead of returning tokens in the body for /api/auth/login and /api/auth/verify-email. Enable Postman's cookie jar (default) so requests to {{baseUrl}} automatically carry the session — no need to manually attach a Bearer token after unified login.\n\nLegacy role logins (/admin/login, /doctor/login, /lab/login) still return a token in the response body and do NOT set cookies — use the Bearer header for those."
  },
  "variable": [
    { "key": "baseUrl",        "value": "http://localhost:4000" },
    { "key": "patientToken",   "value": "" },
    { "key": "doctorToken",    "value": "" },
    { "key": "adminToken",     "value": "" },
    { "key": "labToken",       "value": "" },
    { "key": "doctorId",       "value": "" },
    { "key": "userId",         "value": "" },
    { "key": "appointmentId",  "value": "" },
    { "key": "consultationId", "value": "" },
    { "key": "reportId",       "value": "" },
    { "key": "roomId",         "value": "" },
    { "key": "registerOtp",    "value": "" },
    { "key": "resetOtp",       "value": "" },
    { "key": "pharmacyId",     "value": "" },
    { "key": "productId",      "value": "" },
    { "key": "orderId",        "value": "" },
    { "key": "applicationId",  "value": "" },
    { "key": "scheduleId",     "value": "" }
  ],
  "item": [
    {
      "name": "🩺 Health & Monitoring ✨",
      "item": [
        { "name": "Root Status", "request": { "method": "GET", "url": "{{baseUrl}}/" } },
        { "name": "Health Check", "request": { "method": "GET", "url": "{{baseUrl}}/api/health" } },
        { "name": "Prometheus Metrics", "request": { "method": "GET", "url": "{{baseUrl}}/metrics" } }
      ]
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Patient Register (sends OTP) ✨",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ahmed Mohamed\",\n  \"email\": \"ahmed@test.com\",\n  \"password\": \"password123\"\n}" },
            "description": "No longer logs the user in directly. Creates the account, emails an OTP, and returns { message, user }. Complete the flow with 'Verify Email (OTP)' below."
          }
        },
        {
          "name": "Verify Email (OTP) ✨",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if(r.data?.user?._id) pm.collectionVariables.set('userId', r.data.user._id);"] } }],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/auth/verify-email",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ahmed@test.com\",\n  \"otp\": \"{{registerOtp}}\"\n}" },
            "description": "Sets httpOnly accessToken/refreshToken cookies (Postman's cookie jar stores these automatically for {{baseUrl}}). Paste the OTP received by email into {{registerOtp}}."
          }
        },
        {
          "name": "Resend Verification OTP",
          "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/auth/resend-verification", "body": { "mode": "raw", "raw": "{\n  \"email\": \"ahmed@test.com\"\n}" } }
        },
        {
          "name": "Unified Login (Patient/Admin/Doctor/Lab/Pharmacy) ✨",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ahmed@test.com\",\n  \"password\": \"password123\"\n}" },
            "description": "Auto-detects the role from the email across all 5 account types. Sets httpOnly cookies (accessToken/refreshToken); the response body no longer contains the tokens. Rely on Postman's cookie jar for subsequent requests instead of a Bearer header."
          }
        },
        {
          "name": "Refresh Token (cookie-based) ✨",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/refresh",
            "description": "Reads the refreshToken httpOnly cookie automatically — no request body needed anymore. Re-issues the accessToken cookie."
          }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": "{{baseUrl}}/api/auth/logout" }
        },
        {
          "name": "Forgot Password (sends OTP) ✨",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/auth/forgot-password",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ahmed@test.com\"\n}" },
            "description": "Works across all roles. Always returns a generic success message to prevent email enumeration."
          }
        },
        {
          "name": "Reset Password (with OTP) ✨",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/auth/reset-password",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ahmed@test.com\",\n  \"otp\": \"{{resetOtp}}\",\n  \"newPassword\": \"newPassword123\"\n}" }
          }
        },
        {
          "name": "Resend Reset-Password OTP",
          "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/auth/resend-reset-password", "body": { "mode": "raw", "raw": "{\n  \"email\": \"ahmed@test.com\"\n}" } }
        },
        {
          "name": "Change Password (logged-in)",
          "request": {
            "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"},{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/auth/change-password",
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newPassword123\"\n}" }
          }
        },
        {
          "name": "Admin Login (legacy, body token)",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if(r.data?.token) pm.collectionVariables.set('adminToken', r.data.token);"] } }],
          "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/auth/admin/login", "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@avicena.com\",\n  \"password\": \"StrongAdminPass123\"\n}" } }
        },
        {
          "name": "Doctor Login (legacy, body token)",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if(r.data?.token) pm.collectionVariables.set('doctorToken', r.data.token);"] } }],
          "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/auth/doctor/login", "body": { "mode": "raw", "raw": "{\n  \"email\": \"doctor@test.com\",\n  \"password\": \"password123\"\n}" } }
        },
        {
          "name": "Lab Login (legacy, body token)",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if(r.data?.token) pm.collectionVariables.set('labToken', r.data.token);"] } }],
          "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/auth/lab/login", "body": { "mode": "raw", "raw": "{\n  \"email\": \"lab@test.com\",\n  \"password\": \"password123\"\n}" } }
        }
      ]
    },
    {
      "name": "👤 Patient",
      "item": [
        { "name": "Get Profile", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": "{{baseUrl}}/api/user/profile" } },
        { "name": "Update Profile", "request": { "method": "PUT", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": "{{baseUrl}}/api/user/profile", "body": { "mode": "formdata", "formdata": [{"key":"name","value":"Ahmed Mohamed","type":"text"},{"key":"phone","value":"01012345678","type":"text"},{"key":"gender","value":"ذكر","type":"text"},{"key":"dob","value":"1995-01-01","type":"text"},{"key":"nationality","value":"Egypt","type":"text"},{"key":"nationalId","value":"29501011234567","type":"text"},{"key":"address","value":"{\"line1\":\"Cairo\",\"line2\":\"Nasr City\"}","type":"text"}] } } },
        { "name": "Get User Stats", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": "{{baseUrl}}/api/user/stats" } },
        {
          "name": "Book Appointment",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if(r.data?.appointment?._id) pm.collectionVariables.set('appointmentId', r.data.appointment._id);"] } }],
          "request": { "method": "POST", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/user/appointments", "body": { "mode": "raw", "raw": "{\n  \"docId\": \"{{doctorId}}\",\n  \"slotDate\": \"20_1_2026\",\n  \"slotTime\": \"10:00 am\"\n}" } }
        },
        { "name": "List My Appointments (with Pagination)", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": { "raw": "{{baseUrl}}/api/user/appointments?page=1&limit=10", "query": [{"key":"page","value":"1"},{"key":"limit","value":"10"}] } } },
        { "name": "Cancel Appointment", "request": { "method": "PATCH", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/user/appointments/cancel", "body": { "mode": "raw", "raw": "{\n  \"appointmentId\": \"{{appointmentId}}\"\n}" } } },
        { "name": "Get My Reports", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": "{{baseUrl}}/api/user/reports" } },
        { "name": "Get All Consultations", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": "{{baseUrl}}/api/user/consultations" } },
        { "name": "Get Single Consultation", "request": { "method": "POST", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/user/consultations/single", "body": { "mode": "raw", "raw": "{\n  \"appointmentId\": \"{{appointmentId}}\",\n  \"docId\": \"{{doctorId}}\"\n}" } } },
        { "name": "Update Consultation Time", "request": { "method": "PATCH", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/user/consultations/time", "body": { "mode": "raw", "raw": "{\n  \"consultationId\": \"{{consultationId}}\",\n  \"consultTime\": \"02:00 pm\"\n}" } } },
        { "name": "Cancel Consultation", "request": { "method": "POST", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/user/consultations/cancel", "body": { "mode": "raw", "raw": "{\n  \"consultationId\": \"{{consultationId}}\",\n  \"docId\": \"{{doctorId}}\"\n}" } } }
      ]
    },
    {
      "name": "👨‍⚕️ Doctor",
      "item": [
