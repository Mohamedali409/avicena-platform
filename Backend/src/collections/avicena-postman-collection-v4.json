        { "name": "Cancel Consultation", "request": { "method": "PATCH", "header": [{"key":"dtoken","value":"{{doctorToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/doctor/consultations/cancel", "body": { "mode": "raw", "raw": "{\n  \"consultationId\": \"{{consultationId}}\",\n  \"userId\": \"{{userId}}\"\n}" } } },
        { "name": "Search Patients", "request": { "method": "POST", "header": [{"key":"dtoken","value":"{{doctorToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/doctor/search", "body": { "mode": "raw", "raw": "{\n  \"q\": \"ahmed\"\n}" } } },
