        { "name": "Get Profile", "request": { "method": "GET", "header": [{"key":"dtoken","value":"{{doctorToken}}"}], "url": "{{baseUrl}}/api/doctor/profile" } },
        { "name": "Update Profile", "request": { "method": "PUT", "header": [{"key":"dtoken","value":"{{doctorToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/doctor/profile", "body": { "mode": "raw", "raw": "{\n  \"fees\": 200,\n  \"consultation_fees\": 100,\n  \"available\": true,\n  \"phone\": \"01012345678\",\n  \"address\": {\"line1\": \"Cairo\", \"line2\": \"Nasr City\"},\n  \"start_booked\": {\"from\": 9, \"to\": 17, \"booking_period\": 30}\n}" } } },
        { "name": "Get Dashboard", "request": { "method": "GET", "header": [{"key":"dtoken","value":"{{doctorToken}}"}], "url": "{{baseUrl}}/api/doctor/dashboard" } },
        { "name": "Get Appointments", "request": { "method": "GET", "header": [{"key":"dtoken","value":"{{doctorToken}}"}], "url": "{{baseUrl}}/api/doctor/appointments" } },
        { "name": "Complete Appointment", "request": { "method": "PATCH", "header": [{"key":"dtoken","value":"{{doctorToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/doctor/appointments/complete", "body": { "mode": "raw", "raw": "{\n  \"appointmentId\": \"{{appointmentId}}\"\n}" } } },
        { "name": "Cancel Appointment", "request": { "method": "PATCH", "header": [{"key":"dtoken","value":"{{doctorToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/api/doctor/appointments/cancel", "body": { "mode": "raw", "raw": "{\n  \"appointmentId\": \"{{appointmentId}}\"\n}" } } },
        {
          "name": "Add Report",
