    {
      "name": "💬 Chat + Request Flow ✨",
      "item": [
        {
          "name": "1. Patient — Send Chat Request",
          "request": {
            "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"},{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/chat/request",
            "body": { "mode": "raw", "raw": "{\n  \"docId\": \"{{doctorId}}\",\n  \"initialMessage\": \"دكتور عندي سؤال عن الدواء اللي كتبته\"\n}" },
            "description": "⚠️ Known bug in the current codebase: sendRequest destructures 'doct' from the body but references an undefined 'docId' variable when building the request, which will throw a ReferenceError server-side. Send this exactly as shown; if it 500s, that's the underlying bug, not a client issue."
          }
        },
        {
          "name": "2. Patient — Get My Requests",
          "request": { "method": "POST", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": "{{baseUrl}}/api/chat/my-requests", "description": "Now POST, not GET." }
        },
        {
          "name": "3. Doctor — Get Pending Requests",
          "request": {
            "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{doctorToken}}"}],
            "url": { "raw": "{{baseUrl}}/api/chat/doctor/requests?status=pending", "query": [{"key":"status","value":"pending"}] },
            "description": "Now POST, not GET. Also note this route is protected by the generic authGuard (not doctorGuard) — use 'Authorization: Bearer' with the doctor's token rather than the 'dtoken' header, or it won't authenticate."
          }
        },
        {
          "name": "4. Doctor — Accept Request ✅",
          "request": {
            "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{doctorToken}}"},{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/chat/doctor/request/accept",
            "body": { "mode": "raw", "raw": "{\n  \"roomId\": \"{{roomId}}\"\n}" },
            "description": "Path changed from /doctor/requests/accept to /doctor/request/accept (singular)."
          }
        },
        {
          "name": "4b. Doctor — Reject Request ❌",
          "request": {
            "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{doctorToken}}"},{"key":"Content-Type","value":"application/json"}],
            "url": "{{baseUrl}}/api/chat/doctor/request/reject",
            "body": { "mode": "raw", "raw": "{\n  \"roomId\": \"{{roomId}}\",\n  \"rejectReason\": \"أنا غير متخصص في هذه الحالة\"\n}" }
          }
        },
        {
          "name": "5. Get Room Messages",
          "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": { "raw": "{{baseUrl}}/api/chat/room/{{roomId}}?page=1&limit=30", "query": [{"key":"page","value":"1"},{"key":"limit","value":"30"}] } }
        },
        { "name": "Get My Conversations (Patient)", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{patientToken}}"}], "url": "{{baseUrl}}/api/chat/conversations" } },
        { "name": "Get My Conversations (Doctor)", "request": { "method": "GET", "header": [{"key":"dtoken","value":"{{doctorToken}}"}], "url": "{{baseUrl}}/api/chat/conversations" } },
