            "method": "GET",
            "header": [{ "key": "token", "value": "{{patientToken}}" }],
            "url": "{{baseUrl}}/api/user/consultations"
          }
        },
        {
          "name": "Get Single Consultation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{patientToken}}" }
