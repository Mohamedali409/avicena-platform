{
  "info": {
    "name": "Avicena Platform API v2",
    "description": "Complete & corrected API collection for Avicena Healthcare Platform.\n\n**Auth Headers:**\n- Patient → `token`\n- Doctor  → `dtoken`\n- Admin   → `atoken`\n- Lab     → `ltoken`\n\nAlternatively use `Authorization: Bearer <jwt>` for all roles.",
    "version": "2.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000", "type": "string" },
    { "key": "patientToken", "value": "", "type": "string" },
    { "key": "doctorToken", "value": "", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "labToken", "value": "", "type": "string" },
    { "key": "doctorId", "value": "", "type": "string" },
    { "key": "appointmentId", "value": "", "type": "string" },
    { "key": "consultationId", "value": "", "type": "string" },
    { "key": "reportId", "value": "", "type": "string" },
    { "key": "roomId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Patient Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.data?.token) pm.collectionVariables.set('patientToken', r.data.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Patient\",\n  \"email\": \"newpatient@test.com\",\n  \"password\": \"Test@1234\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Patient Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.data?.token) pm.collectionVariables.set('patientToken', r.data.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ahmed@test.com\",\n  \"password\": \"Patient@1234\"\n}"
