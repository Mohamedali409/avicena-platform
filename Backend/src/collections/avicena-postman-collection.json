    {
      "name": "👤 Patient",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "token", "value": "{{patientToken}}" }],
            "url": "{{baseUrl}}/api/user/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "token", "value": "{{patientToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Ahmed Updated", "type": "text" },
                { "key": "phone", "value": "01099999999", "type": "text" },
                { "key": "gender", "value": "Male", "type": "text" },
                { "key": "dob", "value": "1995-06-15", "type": "text" },
                { "key": "image", "type": "file", "src": "", "disabled": true }
              ]
            },
            "url": "{{baseUrl}}/api/user/profile"
          }
        },
        {
          "name": "Get User Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "token", "value": "{{patientToken}}" }],
            "url": "{{baseUrl}}/api/user/stats"
          }
        },
        {
          "name": "Book Appointment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.data?.appointment?._id) pm.collectionVariables.set('appointmentId', r.data.appointment._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{patientToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"docId\": \"{{doctorId}}\",\n  \"slotDate\": \"2025-09-10\",\n  \"slotTime\": \"10:00\"\n}"
            },
            "url": "{{baseUrl}}/api/user/appointments"
          }
        },
        {
          "name": "List My Appointments",
          "request": {
            "method": "GET",
            "header": [{ "key": "token", "value": "{{patientToken}}" }],
            "url": "{{baseUrl}}/api/user/appointments"
          }
        },
        {
          "name": "Cancel Appointment",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{patientToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentId\": \"{{appointmentId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/user/appointments/cancel"
          }
        },
        {
          "name": "Get My Reports",
          "request": {
            "method": "GET",
            "header": [{ "key": "token", "value": "{{patientToken}}" }],
            "url": "{{baseUrl}}/api/user/reports"
          }
        },
        {
          "name": "Get All Consultations",
