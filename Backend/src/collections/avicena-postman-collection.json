            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentId\": \"{{appointmentId}}\",\n  \"docId\": \"{{doctorId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/user/consultations/single"
          }
