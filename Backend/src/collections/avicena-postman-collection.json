            "url": "{{baseUrl}}/api/user/consultations/time"
          }
        },
        {
          "name": "Cancel Consultation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{patientToken}}" }
